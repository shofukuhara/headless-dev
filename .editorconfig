root = true

# デフォルト設定(全ファイル)
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# HTML
[*.html]
indent_size = 2

# Astro
[*.astro]
indent_size = 2

# PHP
[*.php]
indent_size = 2

# JavaScript/TypeScript (ES/CJS含む)
[*.{js,jsx,ts,tsx,mjs,cjs}]
indent_size = 2

# JSON
[*.{json,jsonc}]
indent_size = 2

# package.json (スペース2つが推奨)
[package.json]
indent_size = 2

# 設定ファイル
[{.prettierrc,.eslintrc,.babelrc,.stylelintrc}]
indent_size = 2

# 環境変数ファイル
[.env*]
indent_size = 2

# Markdown (末尾空白を保持)
[*.md]
indent_size = 2
trim_trailing_whitespace = false

# CSS/SCSS/PostCSS
[*.{css,scss,postcss}]
indent_size = 2

# YAML
[*.{yml,yaml}]
indent_size = 2

# SVG/画像関連ファイル (末尾空白処理を無効化)
[*.{svg,xml}]
insert_final_newline = false
trim_trailing_whitespace = false

# Makefiles (タブが必須)
[Makefile]
indent_style = tab

# バッチファイル
[*.{bat,cmd}]
end_of_line = crlf

---
import Footer from "@/components/common/Footer.astro";
import Header from "@/components/common/Header.astro";
import Base from "@/layouts/Base.astro";

const services = [
  {
    id: "web-consulting",
    title: "Webコンサルティング",
    subtitle: "Web Consulting",
    icon: `<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
      <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
      <line x1="12" y1="22.08" x2="12" y2="12"></line>
    </svg>`,
    description: "デジタルマーケティング戦略の立案から実行まで、お客様のビジネス成長を包括的にサポートします。",
    features: [
      "デジタル戦略立案",
      "SEO/SEM対策",
      "アクセス解析・改善提案",
      "コンテンツマーケティング",
      "SNSマーケティング支援"
    ],
    benefits: "最新のマーケティング手法とデータ分析により、確実な成果を導き出します。"
  },
  {
    id: "system-development",
    title: "システム開発",
    subtitle: "System Development",
    icon: `<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
      <line x1="8" y1="21" x2="16" y2="21"></line>
      <line x1="12" y1="17" x2="12" y2="21"></line>
    </svg>`,
    description: "最新技術を活用したスケーラブルで高品質なシステムを開発し、ビジネスの効率化を実現します。",
    features: [
      "Webアプリケーション開発",
      "モバイルアプリ開発",
      "業務システム開発",
      "API開発・連携",
      "保守・運用サポート"
    ],
    benefits: "アジャイル開発手法により、柔軟かつスピーディーにプロジェクトを進行します。"
  },
  {
    id: "cloud-solution",
    title: "クラウドソリューション",
    subtitle: "Cloud Solution",
    icon: `<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"></path>
    </svg>`,
    description: "クラウド環境の設計・構築から運用まで、セキュアで柔軟なインフラを提供します。",
    features: [
      "クラウド移行支援",
      "インフラ設計・構築",
      "セキュリティ対策",
      "コスト最適化",
      "24時間監視・運用"
    ],
    benefits: "AWS、Azure、GCPなど主要クラウドプラットフォームに対応し、最適な環境を提案します。"
  },
  {
    id: "digital-marketing",
    title: "デジタルマーケティング",
    subtitle: "Digital Marketing",
    icon: `<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="12" y1="1" x2="12" y2="23"></line>
      <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
    </svg>`,
    description: "データドリブンなマーケティング施策で、ROI最大化を目指します。",
    features: [
      "Web広告運用",
      "マーケティングオートメーション",
      "データ分析・レポーティング",
      "UI/UX改善",
      "コンバージョン最適化"
    ],
    benefits: "専門チームによる戦略的な広告運用で、確実な成果を実現します。"
  },
  {
    id: "it-infrastructure",
    title: "ITインフラ構築・運用",
    subtitle: "IT Infrastructure",
    icon: `<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect>
      <rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect>
      <line x1="6" y1="6" x2="6.01" y2="6"></line>
      <line x1="6" y1="18" x2="6.01" y2="18"></line>
    </svg>`,
    description: "安定したITインフラの構築と運用で、ビジネスの継続性を支えます。",
    features: [
      "サーバー構築・管理",
      "ネットワーク設計・構築",
      "セキュリティ対策",
      "障害対応・復旧支援",
      "定期メンテナンス"
    ],
    benefits: "24時間365日の監視体制で、安心・安全なシステム運用を実現します。"
  },
  {
    id: "consulting",
    title: "IT戦略コンサルティング",
    subtitle: "IT Strategy Consulting",
    icon: `<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="12" cy="12" r="10"></circle>
      <polyline points="12 6 12 12 16 14"></polyline>
    </svg>`,
    description: "経営課題をITで解決するための戦略立案から実行支援まで、トータルでサポートします。",
    features: [
      "IT戦略立案",
      "DX推進支援",
      "業務プロセス改善",
      "システム選定支援",
      "プロジェクトマネジメント"
    ],
    benefits: "豊富な経験と実績を活かし、お客様に最適なソリューションを提供します。"
  }
];

const flow = [
  {
    step: "01",
    title: "お問い合わせ・ヒアリング",
    description: "まずはお気軽にお問い合わせください。お客様の課題やご要望を詳しくヒアリングします。"
  },
  {
    step: "02",
    title: "提案・お見積もり",
    description: "ヒアリング内容をもとに、最適なソリューションをご提案し、お見積もりを提示します。"
  },
  {
    step: "03",
    title: "契約・プロジェクト開始",
    description: "ご契約後、専任チームを編成し、プロジェクトをスタートします。"
  },
  {
    step: "04",
    title: "開発・実行",
    description: "定期的な進捗報告を行いながら、計画に沿ってプロジェクトを推進します。"
  },
  {
    step: "05",
    title: "納品・運用開始",
    description: "納品後も継続的なサポートで、安定した運用をお手伝いします。"
  }
];
---

<Base pageMeta="service" pageData="service">
  <Header />
  <main>
    <!-- Page Hero -->
    <section class="page-hero">
      <div class="container">
        <h1 class="page-title">サービス</h1>
        <p class="page-description">Our Services</p>
      </div>
    </section>

    <!-- Services Section -->
    <section class="services-section">
      <div class="container">
        <div class="services-intro">
          <h2 class="section-title">お客様のビジネスを<br class="sp-only" />加速させるソリューション</h2>
          <p class="section-description">
            最新のテクノロジーと確かな実績で、お客様のニーズに合わせた最適なサービスを提供します
          </p>
        </div>

        <div class="services-grid">
          {services.map((service, index) => (
            <div class="service-card" data-index={index}>
              <div class="service-header">
                <div class="service-icon" set:html={service.icon} />
                <div class="service-title-group">
                  <h3>{service.title}</h3>
                  <p class="subtitle">{service.subtitle}</p>
                </div>
              </div>
              <p class="service-description">{service.description}</p>
              <div class="service-features">
                <h4>主な機能・サービス</h4>
                <ul>
                  {service.features.map((feature) => (
                    <li>{feature}</li>
                  ))}
                </ul>
              </div>
              <div class="service-benefits">
                <strong>特徴：</strong>
                <p>{service.benefits}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Flow Section -->
    <section class="flow-section">
      <div class="container">
        <h2 class="section-title">サービス導入の流れ</h2>
        <p class="section-description">お問い合わせから運用開始までの標準的な流れをご紹介します</p>

        <div class="flow-grid">
          {flow.map((item) => (
            <div class="flow-item">
              <div class="flow-step">{item.step}</div>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta">
      <div class="container cta-content">
        <h2>サービスについてのご相談</h2>
        <p>どのサービスがお客様に最適か、お気軽にご相談ください。専門スタッフが丁寧にご案内いたします</p>
        <a href="/contact" class="btn btn-white">お問い合わせ</a>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  :root {
    --primary: #2563eb;
    --primary-dark: #1e40af;
    --primary-light: #dbeafe;
    --text: #0f172a;
    --text-light: #64748b;
    --bg-gray: #f8fafc;
    --border: #e2e8f0;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Page Hero */
  .page-hero {
    padding: 180px 0 100px;
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    color: white;
    text-align: center;
  }

  .page-title {
    font-size: 48px;
    font-weight: 700;
    margin-bottom: 16px;
  }

  .page-description {
    font-size: 18px;
    opacity: 0.9;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  /* Services Section */
  .services-section {
    padding: 120px 0;
    background: white;
  }

  .services-intro {
    text-align: center;
    margin-bottom: 80px;
  }

  .section-title {
    font-size: 42px;
    font-weight: 700;
    margin-bottom: 24px;
    line-height: 1.4;
  }

  .section-description {
    color: var(--text-light);
    font-size: 18px;
    line-height: 1.8;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 40px;
  }

  .service-card {
    background: white;
    border: 2px solid var(--border);
    border-radius: 16px;
    padding: 40px;
    transition: all 0.3s;
  }

  .service-card:hover {
    border-color: var(--primary);
    box-shadow: 0 20px 40px rgba(37, 99, 235, 0.1);
    transform: translateY(-4px);
  }

  .service-header {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    margin-bottom: 24px;
  }

  .service-icon {
    width: 64px;
    height: 64px;
    background: var(--primary-light);
    color: var(--primary);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .service-title-group h3 {
    font-size: 22px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 4px;
  }

  .subtitle {
    font-size: 13px;
    color: var(--text-light);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .service-description {
    color: var(--text-light);
    line-height: 1.8;
    margin-bottom: 24px;
  }

  .service-features {
    margin-bottom: 24px;
    padding: 24px;
    background: var(--bg-gray);
    border-radius: 8px;
  }

  .service-features h4 {
    font-size: 14px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 16px;
  }

  .service-features ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .service-features li {
    padding: 8px 0;
    padding-left: 20px;
    position: relative;
    color: var(--text-light);
    font-size: 14px;
  }

  .service-features li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--primary);
    font-weight: bold;
  }

  .service-benefits {
    padding: 16px;
    background: var(--primary-light);
    border-radius: 8px;
    border-left: 3px solid var(--primary);
  }

  .service-benefits strong {
    color: var(--primary);
    font-size: 14px;
  }

  .service-benefits p {
    color: var(--text);
    font-size: 14px;
    line-height: 1.6;
    margin-top: 8px;
  }

  /* Flow Section */
  .flow-section {
    padding: 120px 0;
    background: var(--bg-gray);
  }

  .flow-section .section-title {
    text-align: center;
  }

  .flow-section .section-description {
    text-align: center;
    margin-bottom: 60px;
  }

  .flow-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 32px;
    max-width: 1000px;
    margin: 0 auto;
  }

  .flow-item {
    background: white;
    padding: 32px 24px;
    border-radius: 12px;
    text-align: center;
    position: relative;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .flow-step {
    width: 56px;
    height: 56px;
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 18px;
    margin: 0 auto 16px;
  }

  .flow-item h3 {
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 12px;
  }

  .flow-item p {
    font-size: 14px;
    color: var(--text-light);
    line-height: 1.6;
  }

  /* CTA */
  .cta {
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    padding: 100px 0;
    color: white;
    text-align: center;
  }

  .cta-content h2 {
    font-size: 36px;
    margin-bottom: 16px;
  }

  .cta-content p {
    font-size: 18px;
    margin-bottom: 32px;
    opacity: 0.95;
  }

  .btn {
    padding: 14px 32px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s;
    display: inline-block;
  }

  .btn-white {
    background: white;
    color: var(--primary);
  }

  .btn-white:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
  }

  .sp-only {
    display: none;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .page-title {
      font-size: 36px;
    }

    .section-title {
      font-size: 32px;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .flow-grid {
      grid-template-columns: 1fr;
    }

    .sp-only {
      display: inline;
    }
  }
</style>

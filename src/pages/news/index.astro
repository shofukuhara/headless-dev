    slug: "10th-anniversary",
  },
];

const categories = ["すべて", "お知らせ", "プレスリリース", "サービス", "イベント"];
---

<Base pageMeta="news" pageData="news">
  <Header />
  <main>
    <!-- Page Hero -->
    <section class="page-hero">
      <div class="container">
        <h1 class="page-title">ニュース</h1>
        <p class="page-description">News</p>
      </div>
    </section>

    <!-- News Section -->
    <section class="news-section">
      <div class="container">
        <!-- Category Filter -->
        <div class="category-filter">
          {
            categories.map((cat) => (
              <button class={cat === "すべて" ? "category-btn active" : "category-btn"}>
                {cat}
              </button>
            ))
          }
        </div>

        <!-- News List -->
        <div class="news-list">
          {
            newsList.map((news) => (
              <article class="news-card">
                <a href={`/news/${news.slug}`} class="news-link">
                  <div class="news-meta">
                    <time class="news-date">{news.date}</time>
                    <span class={`news-category category-${news.category}`}>{news.category}</span>
                  </div>
                  <h2 class="news-title">{news.title}</h2>
                  <p class="news-excerpt">{news.excerpt}</p>
                  <div class="read-more">
                    続きを読む
                    <svg
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <line x1="5" y1="12" x2="19" y2="12" />
                      <polyline points="12 5 19 12 12 19" />
                    </svg>
                  </div>
                </a>
              </article>
            ))
          }
        </div>

        <!-- Pagination -->
        <div class="pagination">
          <button class="pagination-btn disabled">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
          </button>
          <button class="pagination-btn active">1</button>
          <button class="pagination-btn">2</button>
          <button class="pagination-btn">3</button>
          <span class="pagination-dots">...</span>
          <button class="pagination-btn">10</button>
          <button class="pagination-btn">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </button>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  :root {
    --primary: #2563eb;
    --primary-dark: #1e40af;
    --primary-light: #dbeafe;
    --text: #0f172a;
    --text-light: #64748b;
    --bg-gray: #f8fafc;
    --border: #e2e8f0;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Page Hero */
  .page-hero {
    padding: 180px 0 100px;
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    color: white;
    text-align: center;
  }

  .page-title {
    font-size: 48px;
    font-weight: 700;
    margin-bottom: 16px;
  }

  .page-description {
    font-size: 18px;
    opacity: 0.9;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  /* News Section */
  .news-section {
    padding: 120px 0;
    background: var(--bg-gray);
  }

  /* Category Filter */
  .category-filter {
    display: flex;
    gap: 12px;
    margin-bottom: 60px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .category-btn {
    padding: 10px 24px;
    background: white;
    color: var(--text-light);
    border: 2px solid var(--border);
    border-radius: 24px;
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.3s;
  }

  .category-btn:hover {
    border-color: var(--primary);
    color: var(--primary);
  }

  .category-btn.active {
    background: var(--primary);
    color: white;
    border-color: var(--primary);
  }

  /* News List */
  .news-list {
    display: grid;
    gap: 32px;
    margin-bottom: 60px;
  }

  .news-card {
    background: white;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    transition: all 0.3s;
  }

  .news-card:hover {
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.1);
    transform: translateY(-4px);
  }

  .news-link {
    display: block;
    padding: 32px;
    text-decoration: none;
    color: inherit;
  }

  .news-meta {
    display: flex;
    gap: 16px;
    align-items: center;
    margin-bottom: 16px;
  }

  .news-date {
    color: var(--text-light);
    font-size: 14px;
    font-weight: 500;
  }

  .news-category {
    padding: 6px 14px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 600;
  }

  .category-お知らせ {
    background: #dbeafe;
    color: #2563eb;
  }

  .category-プレスリリース {
    background: #fce7f3;
    color: #ec4899;
  }

  .category-サービス {
    background: #dcfce7;
    color: #16a34a;
  }

  .category-イベント {
    background: #fef3c7;
    color: #f59e0b;
  }

  .news-title {
    font-size: 22px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 12px;
    line-height: 1.5;
  }

  .news-excerpt {
    color: var(--text-light);
    line-height: 1.7;
    margin-bottom: 20px;
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--primary);
    font-weight: 600;
    font-size: 14px;
    transition: gap 0.3s;
  }

  .news-card:hover .read-more {
    gap: 12px;
  }

  /* Pagination */
  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
  }

  .pagination-btn {
    min-width: 44px;
    height: 44px;
    padding: 0 12px;
    background: white;
    color: var(--text);
    border: 2px solid var(--border);
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pagination-btn:hover:not(.disabled) {
    border-color: var(--primary);
    color: var(--primary);
  }

  .pagination-btn.active {
    background: var(--primary);
    color: white;
    border-color: var(--primary);
  }

  .pagination-btn.disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .pagination-dots {
    padding: 0 8px;
    color: var(--text-light);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .page-title {
      font-size: 36px;
    }

    .category-filter {
      justify-content: flex-start;
    }

    .news-link {
      padding: 24px;
    }

    .news-title {
      font-size: 18px;
    }

    .pagination {
      flex-wrap: wrap;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const categoryButtons = document.querySelectorAll(".category-btn");

    categoryButtons.forEach((button) => {
      button.addEventListener("click", () => {
        categoryButtons.forEach((btn) => btn.classList.remove("active"));
        button.classList.add("active");
      });
    });
  });
</script>

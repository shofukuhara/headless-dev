    excerpt:
      "より高度なセキュリティと拡張性を備えた新しいクラウドサービスの提供を開始いたしました。",
    slug: "cloud-solution-pro-release",
  },
  {
    id: 2,
    date: "2026.01.15",
    category: "プレスリリース",
    title: "東京オフィス拡張移転のお知らせ",
    excerpt: "事業拡大に伴い、2026年3月1日より東京オフィスを移転・拡張することになりました。",
    slug: "office-relocation",
  },
  {
    id: 3,
    date: "2026.01.10",
    category: "お知らせ",
    title: "年末年始の営業日について",
    excerpt: "誠に勝手ながら、下記の期間を年末年始休業とさせていただきます。",
    slug: "year-end-holidays",
  },
  {
    id: 4,
    date: "2025.12.25",
    category: "イベント",
    title: "「DX推進セミナー 2026」開催のお知らせ",
    excerpt: "2026年2月15日に、企業のデジタル変革をテーマにしたセミナーを開催いたします。",
    slug: "dx-seminar-2026",
  },
  {
    id: 5,
    date: "2025.12.18",
    category: "プレスリリース",
    title: "大手製造業A社との業務提携契約締結について",
    excerpt: "製造業向けIoTソリューションの共同開発に関する業務提携契約を締結いたしました。",
    slug: "partnership-announcement",
  },
  {
    id: 6,
    date: "2025.12.10",
    category: "お知らせ",
    title: "ISO27001認証を取得しました",
    excerpt: "情報セキュリティマネジメントシステムの国際規格ISO27001の認証を取得いたしました。",

    id: 9,
    date: "2025.11.10",
    category: "お知らせ",
    title: "福岡支社開設のお知らせ",
    excerpt: "九州エリアでのサービス拡充のため、福岡市に新たな支社を開設いたしました。",
    slug: "fukuoka-office-opening",
  },
  {
    id: 10,
    date: "2025.11.01",
    category: "プレスリリース",
    title: "採用活動強化について - 新卒・中途採用を積極募集",

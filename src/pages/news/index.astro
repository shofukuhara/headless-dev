  },
  {
    id: 7,
    date: "2025.12.01",
    category: "サービス",
    title: "AIチャットボットサービスの提供開始",
    excerpt: "最新のAI技術を活用したカスタマーサポート向けチャットボットサービスを開始しました。",
    slug: "ai-chatbot-service",
  },
  {
    id: 8,
    date: "2025.11.20",
    category: "イベント",
    title: "技術カンファレンス「Tech Summit 2025」に登壇",
    excerpt: "当社CTOが最新のクラウド技術について講演を行いました。",
